<Application x:Class="AshenVoice.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="AshBrush" Color="#FF17191D"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FF24272D"/>
        <SolidColorBrush x:Key="EmberBrush" Color="#FFF07132"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFF4F4F4"/>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="{StaticResource EmberBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Application.Resources>
</Application>
