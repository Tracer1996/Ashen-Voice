<Window x:Class="AshenVoice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ashen Voice"
        Width="1120"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        Background="{StaticResource AshBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="ASHEN VOICE" FontSize="30" FontWeight="Bold" Foreground="{StaticResource EmberBrush}"/>
            <TextBlock Text="Discord speaker overlay for fullscreen classic World of Warcraft." FontSize="14" Opacity="0.78"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource StatusCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="APPLICATION" FontSize="11" Opacity="0.65"/>
                    <TextBlock x:Name="AppStatusText" Text="Running" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatusCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="WOW CLIENT" FontSize="11" Opacity="0.65"/>
                    <TextBlock x:Name="WowStatusText" Text="Not detected" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatusCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="OVERLAY" FontSize="11" Opacity="0.65"/>
                    <TextBlock x:Name="OverlayStatusText" Text="Ready" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatusCardStyle}">
                <StackPanel>
                    <TextBlock Text="DISCORD" FontSize="11" Opacity="0.65"/>
                    <TextBlock x:Name="DiscordStatusText" Text="Disconnected" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="470"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="12" Margin="0,0,12,0">
                <TabControl>
                    <TabItem Header="Controls">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="Overlay" Style="{StaticResource SectionTitleStyle}"/>
                                <Button x:Name="StartOverlayButton" Content="Start Overlay" Click="StartOverlayButton_Click"/>
                                <Button x:Name="StopOverlayButton" Content="Stop Overlay" Click="StopOverlayButton_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                                <Button x:Name="PreviewOverlayButton" Content="Preview Overlay" Click="PreviewOverlayButton_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                                <TextBlock Text="Start the overlay, then click Preview Overlay." Style="{StaticResource HelpTextStyle}"/>

                                <Separator Margin="0,14"/>
                                <TextBlock Text="Discord" Style="{StaticResource SectionTitleStyle}"/>
                                <Border Background="#FF1A1C21" CornerRadius="7" Padding="12" Margin="4,0,4,10">
                                    <StackPanel>
                                        <TextBlock x:Name="DiscordAccountText" Text="Not connected" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="DiscordVoiceText" Text="Join a voice channel." Margin="0,5,0,0" Opacity="0.68" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="ConnectDiscordButton" Content="Connect Discord" Click="ConnectDiscordButton_Click"/>
                                <Button x:Name="DisconnectDiscordButton" Content="Disconnect Discord" Click="DisconnectDiscordButton_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                                <TextBlock Text="Open Discord, join a voice channel, then click Connect Discord." Style="{StaticResource HelpTextStyle}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Overlay Settings">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="Position" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Screen corner" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="PositionComboBox" Margin="4,0,4,10" SelectionChanged="OverlaySettingChanged">
                                    <ComboBoxItem Content="Top Right" Tag="TopRight"/>
                                    <ComboBoxItem Content="Top Left" Tag="TopLeft"/>
                                    <ComboBoxItem Content="Bottom Right" Tag="BottomRight"/>
                                    <ComboBoxItem Content="Bottom Left" Tag="BottomLeft"/>
                                </ComboBox>

                                <Grid Margin="4,0,4,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Horizontal offset (-10000 to 10000)" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,5"/>
                                        <TextBox x:Name="HorizontalOffsetTextBox" Text="18" Padding="8" LostFocus="OverlayNumberTextBox_LostFocus"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Vertical offset (-10000 to 10000)" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,5"/>
                                        <TextBox x:Name="VerticalOffsetTextBox" Text="34" Padding="8" LostFocus="OverlayNumberTextBox_LostFocus"/>
                                    </StackPanel>
                                </Grid>

                                <Separator Margin="0,8,0,14"/>
                                <TextBlock Text="Size and Style" Style="{StaticResource SectionTitleStyle}"/>

                                <DockPanel Margin="4,3">
                                    <TextBlock Text="Scale" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="OverlayScaleValueText" Text="100%" DockPanel.Dock="Right" Opacity="0.7"/>
                                </DockPanel>
                                <Slider x:Name="OverlayScaleSlider" Minimum="0.75" Maximum="1.50" Value="1" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OverlaySettingChanged"/>

                                <DockPanel Margin="4,10,4,3">
                                    <TextBlock Text="Card width" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="CardWidthValueText" Text="218 px" DockPanel.Dock="Right" Opacity="0.7"/>
                                </DockPanel>
                                <Slider x:Name="CardWidthSlider" Minimum="150" Maximum="300" Value="218" TickFrequency="2" IsSnapToTickEnabled="True" ValueChanged="OverlaySettingChanged"/>

                                <DockPanel Margin="4,10,4,3">
                                    <TextBlock Text="Avatar size" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="AvatarSizeValueText" Text="36 px" DockPanel.Dock="Right" Opacity="0.7"/>
                                </DockPanel>
                                <Slider x:Name="AvatarSizeSlider" Minimum="24" Maximum="52" Value="36" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OverlaySettingChanged"/>

                                <DockPanel Margin="4,10,4,3">
                                    <TextBlock Text="Name size" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="FontSizeValueText" Text="17 px" DockPanel.Dock="Right" Opacity="0.7"/>
                                </DockPanel>
                                <Slider x:Name="FontSizeSlider" Minimum="12" Maximum="22" Value="17" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OverlaySettingChanged"/>

                                <DockPanel Margin="4,10,4,3">
                                    <TextBlock Text="Background opacity" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="BackgroundOpacityValueText" Text="70%" DockPanel.Dock="Right" Opacity="0.7"/>
                                </DockPanel>
                                <Slider x:Name="BackgroundOpacitySlider" Minimum="0" Maximum="100" Value="70" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="OverlaySettingChanged"/>

                                <DockPanel Margin="4,10,4,3">
                                    <TextBlock Text="Speaking ring" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="RingThicknessValueText" Text="3 px" DockPanel.Dock="Right" Opacity="0.7"/>
                                </DockPanel>
                                <Slider x:Name="RingThicknessSlider" Minimum="1" Maximum="5" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OverlaySettingChanged"/>

                                <Separator Margin="0,14"/>
                                <TextBlock Text="Behavior" Style="{StaticResource SectionTitleStyle}"/>

                                <DockPanel Margin="4,3">
                                    <TextBlock Text="Maximum speakers" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="MaximumSpeakersValueText" Text="5" DockPanel.Dock="Right" Opacity="0.7"/>
                                </DockPanel>
                                <Slider x:Name="MaximumSpeakersSlider" Minimum="1" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OverlaySettingChanged"/>

                                <DockPanel Margin="4,10,4,3">
                                    <TextBlock Text="Hide delay" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="HideDelayValueText" Text="0.5 sec" DockPanel.Dock="Right" Opacity="0.7"/>
                                </DockPanel>
                                <Slider x:Name="HideDelaySlider" Minimum="0.2" Maximum="3.0" Value="0.5" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="OverlaySettingChanged"/>

                                <CheckBox x:Name="ShowAvatarCheckBox" Content="Show avatars" Margin="4,14,4,6" Checked="OverlaySettingChanged" Unchecked="OverlaySettingChanged"/>
                                <CheckBox x:Name="ShowNameCheckBox" Content="Show names" Margin="4,6" Checked="OverlaySettingChanged" Unchecked="OverlaySettingChanged"/>

                                <Button Content="Reset Overlay Settings" Click="ResetOverlaySettingsButton_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="4,16,4,4"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Application">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="Application" Style="{StaticResource SectionTitleStyle}"/>
                                <Button x:Name="StartButton" Content="Start Monitoring" Click="StartButton_Click"/>
                                <Button x:Name="StopButton" Content="Stop Monitoring" Click="StopButton_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                                <Button Content="Check for WoW" Click="CheckNowButton_Click" Style="{StaticResource SecondaryButtonStyle}"/>

                                <CheckBox x:Name="MinimizeToTrayCheckBox" Content="Minimize to system tray" Margin="4,14,4,6" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows" Margin="4,6" Checked="SettingChanged" Unchecked="SettingChanged"/>

                                <TextBlock Text="Detected process names" Margin="4,18,4,5" Opacity="0.72"/>
                                <TextBox x:Name="ProcessNamesTextBox" Text="Wow, WoW, OctoWoW" Margin="4" Padding="8" LostFocus="ProcessNamesTextBox_LostFocus"/>
                                <TextBlock Text="Separate names with commas. Do not include .exe." Style="{StaticResource HelpTextStyle}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Activity Log" FontSize="20" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <Button Content="Clear" Click="ClearLogButton_Click" DockPanel.Dock="Right" Style="{StaticResource SecondaryButtonStyle}" Padding="10,4"/>
                    </DockPanel>
                    <TextBox x:Name="LogTextBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#FF111317" Foreground="#FFE8E8E8" BorderThickness="0" Padding="12" FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Text="Phase 4 • Settings and visual quality" Opacity="0.6" DockPanel.Dock="Left"/>
            <TextBlock x:Name="VersionText" Text="v1.4.4" Opacity="0.6" DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
