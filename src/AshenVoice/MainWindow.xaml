<Window x:Class="AshenVoice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ashen Voice"
        Width="1080"
        Height="730"
        MinWidth="930"
        MinHeight="640"
        Background="{StaticResource AshBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="ASHEN VOICE" FontSize="30" FontWeight="Bold" Foreground="{StaticResource EmberBrush}"/>
            <TextBlock Text="Compact Discord speaker overlay for fullscreen classic World of Warcraft clients" FontSize="14" Opacity="0.78"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="APPLICATION" FontSize="11" Opacity="0.65"/>
                    <TextBlock x:Name="AppStatusText" Text="Running" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="WOW CLIENT" FontSize="11" Opacity="0.65"/>
                    <TextBlock x:Name="WowStatusText" Text="Not detected" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="OVERLAY" FontSize="11" Opacity="0.65"/>
                    <TextBlock x:Name="OverlayStatusText" Text="Ready" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14">
                <StackPanel>
                    <TextBlock Text="DISCORD" FontSize="11" Opacity="0.65"/>
                    <TextBlock x:Name="DiscordStatusText" Text="Disconnected" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18" Margin="0,0,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Overlay" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Button x:Name="StartOverlayButton" Content="Start Overlay" Click="StartOverlayButton_Click"/>
                        <Button x:Name="StopOverlayButton" Content="Stop Overlay" Click="StopOverlayButton_Click" Background="#FF4B4F58"/>
                        <Button x:Name="PreviewOverlayButton" Content="Preview Compact Style" Click="PreviewOverlayButton_Click" Background="#FF4B4F58"/>
                        <TextBlock Text="The overlay stays hidden until somebody speaks. Preview displays three temporary rows for eight seconds." FontSize="11" Margin="4,5,4,2" Opacity="0.65" TextWrapping="Wrap"/>

                        <Separator Margin="0,14"/>
                        <TextBlock Text="Discord" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Border Background="#FF1A1C21" CornerRadius="7" Padding="12" Margin="4,0,4,10">
                            <StackPanel>
                                <TextBlock x:Name="DiscordAccountText" Text="Not connected" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock x:Name="DiscordVoiceText" Text="Active voice channel will be detected automatically" Margin="0,5,0,0" Opacity="0.68" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="ConnectDiscordButton" Content="Connect Discord" Click="ConnectDiscordButton_Click"/>
                        <Button x:Name="DisconnectDiscordButton" Content="Disconnect Discord" Click="DisconnectDiscordButton_Click" Background="#FF4B4F58"/>
                        <TextBlock Text="Uses the Discord desktop app already running on this computer. No bot, bridge, server ID, channel ID, or voice recording." FontSize="11" Margin="4,5,4,2" Opacity="0.65" TextWrapping="Wrap"/>

                        <Separator Margin="0,14"/>
                        <TextBlock Text="Application" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Button x:Name="StartButton" Content="Start Ashen Voice" Click="StartButton_Click"/>
                        <Button x:Name="StopButton" Content="Stop Ashen Voice" Click="StopButton_Click" Background="#FF4B4F58"/>
                        <Button Content="Check for WoW Now" Click="CheckNowButton_Click" Background="#FF4B4F58"/>

                        <CheckBox x:Name="MinimizeToTrayCheckBox" Content="Minimize to system tray" Margin="4,12,4,6" Checked="SettingChanged" Unchecked="SettingChanged"/>
                        <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start Ashen Voice with Windows" Margin="4,6" Checked="SettingChanged" Unchecked="SettingChanged"/>
                        <TextBlock Text="Detected process names" Margin="4,16,4,5" Opacity="0.72"/>
                        <TextBox x:Name="ProcessNamesTextBox" Text="Wow, WoW, OctoWoW" Margin="4" Padding="8" LostFocus="ProcessNamesTextBox_LostFocus"/>
                        <TextBlock Text="Separate names with commas. Do not include .exe." FontSize="11" Margin="4,3" Opacity="0.58" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Activity Log" FontSize="20" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <Button Content="Clear" Click="ClearLogButton_Click" DockPanel.Dock="Right" Background="#FF4B4F58" Padding="10,4"/>
                    </DockPanel>

                    <Border Grid.Row="1" Background="#FF1A1C21" CornerRadius="7" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Direct Discord Connection" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Click Connect Discord once. Ashen Voice follows whichever voice channel your active Discord desktop account joins and only displays members while they are speaking." Margin="0,5,0,0" TextWrapping="Wrap" Opacity="0.72"/>
                        </StackPanel>
                    </Border>

                    <TextBox x:Name="LogTextBox" Grid.Row="2" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#FF111317" Foreground="#FFE8E8E8" BorderThickness="0" Padding="12" FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Text="Phase 3.1 • Local Discord RPC connection probe" Opacity="0.6" DockPanel.Dock="Left"/>
            <TextBlock x:Name="VersionText" Text="v1.3.0-alpha" Opacity="0.6" DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
